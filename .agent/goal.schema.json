{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-goal.schema.json",
  "title": "Agent Runtime Goal Contract",
  "type": "object",
  "required": ["schema_version", "goal_id", "objective", "target_refs", "core_constraints", "verification", "assertions", "exit_gates", "risk_policy"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\.0$"},
    "goal_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"},
    "objective": {"type": "string", "minLength": 20},
    "target_refs": {"type": "array", "items": {"type": "string"}},
    "core_constraints": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "verification": {
      "type": "object",
      "required": ["primary_command", "oracle_strength", "evidence_artifacts"],
      "properties": {
        "primary_command": {"type": "string"},
        "oracle_strength": {"type": "integer", "minimum": 1, "maximum": 5},
        "evidence_artifacts": {"type": "array", "items": {"type": "string"}}
      }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "command", "risk_class", "expected_evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_:-]+$"},
          "description": {"type": "string"},
          "command": {"type": "string"},
          "risk_class": {"type": "integer", "minimum": 0, "maximum": 4},
          "expected_evidence": {"type": "string"}
        }
      }
    },
    "exit_gates": {
      "type": "object",
      "required": ["max_retries", "max_consecutive_errors", "hard_blockers"],
      "properties": {
        "max_retries": {"type": "integer", "minimum": 1, "maximum": 50},
        "max_consecutive_errors": {"type": "integer", "minimum": 1, "maximum": 10},
        "hard_blockers": {"type": "array", "items": {"type": "string"}}
      }
    },
    "risk_policy": {
      "type": "object",
      "required": ["allowed_without_approval", "approval_required", "forbidden"],
      "properties": {
        "allowed_without_approval": {"type": "array", "items": {"type": "string"}},
        "approval_required": {"type": "array", "items": {"type": "string"}},
        "forbidden": {"type": "array", "items": {"type": "string"}}
      }
    },
    "current_phase": {"type": "string"},
    "updated_at": {"type": "string"}
  }
}
